# AI Model Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=your_gemini_model_name
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Application Settings
MAX_CHAPTER_LENGTH=2000
MAX_CHOICES=4
DEFAULT_NOVEL_STYLE=修仙

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Neo4j Aura Configuration (if using Neo4j Aura)
AURA_INSTANCEID=your_aura_instance_id
AURA_INSTANCENAME=your_aura_instance_name

# Graph Module Configuration
GRAPH_ENABLE_GRAPH_BUILDING=true
GRAPH_CHARACTER_EXTRACTION_ENABLED=true
GRAPH_RELATIONSHIP_ANALYSIS_ENABLED=true
GRAPH_MAX_CHARACTERS_PER_CHAPTER=20
GRAPH_MAX_RELATIONSHIPS_PER_PAIR=3
GRAPH_CHARACTER_IMPORTANCE_THRESHOLD=0.1
GRAPH_ENABLE_CHARACTER_CACHE=true
GRAPH_CACHE_EXPIRY_HOURS=24